# =====================================================
# Quarto build/cache artifacts
# =====================================================

.quarto/
_cache/
_freeze/
_site/

# Ignore rendered HTML outside docs/
*.html
!docs/**/*.html

# Ignore Quarto-generated asset folders outside docs/
*_files/
!docs/*_files/
!docs/*_files/**

# Ignore generated documents
*.pdf
*.docx

# =====================================================
# Python
# =====================================================

.venv/
__pycache__/
*.py[cod]
*.egg-info/

# =====================================================
# Jupyter checkpoints
# =====================================================

.ipynb_checkpoints/

# =====================================================
# OS / Editor
# =====================================================

.DS_Store
Thumbs.db
.vscode/
.idea/

# =====================================================
# Logs
# =====================================================

*.log

/.quarto/
